    <!-- API DOCS VIEW -->
    <div id="docs-view" class="hidden" style="flex:1;overflow-y:auto;padding:28px">
      <div class="page-title" style="margin-bottom:8px">📖 API Reference</div>
      <div class="page-sub" style="margin-bottom:24px">Use these endpoints in any tool — just pass your app's API key</div>
      <div id="docs-content"></div>
    </div>

  </main>
</div>

<!-- CREATE APP MODAL -->
