<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1.0"/>
<title>NitinCloud — Personal BaaS</title>
<link href="https://fonts.googleapis.com/css2?family=Clash+Display:wght@400;500;600;700&family=Cabinet+Grotesk:wght@400;500;700&display=swap" rel="stylesheet"/>
<style>
:root{
  --bg:#07080f;
  --s1:#0c0e1a;
  --s2:#111425;
  --border:#1e2340;
  --border2:#2a3060;
  --acc:#4f6ef7;
  --acc2:#7b93ff;
  --acc3:#a8b8ff;
  --cyan:#38d9c0;
  --pink:#f05fa8;
  --gold:#f0c060;
  --green:#40d480;
  --red:#f05050;
  --text:#e8eaf8;
  --text2:#8890c0;
  --text3:#3a4070;
  --r:10px;
  --sh:0 8px 32px rgba(0,0,0,0.6);
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html,body{height:100%;overflow:hidden}
body{
  background:var(--bg);color:var(--text);
  font-family:'Cabinet Grotesk',sans-serif;font-size:14px;
  display:flex;flex-direction:column;
}

/* ── GRID BG ── */
body::before{
  content:'';position:fixed;inset:0;pointer-events:none;z-index:0;
  background-image:
    linear-gradient(rgba(79,110,247,0.03) 1px,transparent 1px),
    linear-gradient(90deg,rgba(79,110,247,0.03) 1px,transparent 1px);
  background-size:40px 40px;
}

/* ── GLOW ORBS ── */
body::after{
  content:'';position:fixed;inset:0;pointer-events:none;z-index:0;
  background:
    radial-gradient(ellipse 600px 400px at 20% 20%,rgba(79,110,247,0.06),transparent),
    radial-gradient(ellipse 400px 300px at 80% 80%,rgba(56,217,192,0.04),transparent);
}

/* ── TOPBAR ── */
#topbar{
  position:relative;z-index:10;
  display:flex;align-items:center;justify-content:space-between;
  padding:0 24px;height:58px;
  background:rgba(7,8,15,0.9);
  border-bottom:1px solid var(--border);
  backdrop-filter:blur(12px);flex-shrink:0;
}
.brand{display:flex;align-items:center;gap:12px;cursor:pointer}
.brand-logo{
  width:34px;height:34px;border-radius:9px;
  background:linear-gradient(135deg,var(--acc),var(--cyan));
  display:flex;align-items:center;justify-content:center;
  font-family:'Clash Display',sans-serif;font-size:16px;font-weight:700;
  color:#fff;letter-spacing:-0.05em;
  box-shadow:0 0 16px rgba(79,110,247,0.4);
}
.brand-name{
  font-family:'Clash Display',sans-serif;font-size:20px;font-weight:600;
  background:linear-gradient(90deg,var(--acc2),var(--cyan));
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;
  letter-spacing:-0.02em;
}
.brand-tag{
  font-size:10px;color:var(--text3);letter-spacing:0.12em;
  text-transform:uppercase;
}
.topbar-right{display:flex;align-items:center;gap:12px}
#server-url-display{
  font-size:11px;color:var(--text2);
  background:var(--s2);border:1px solid var(--border);
  border-radius:6px;padding:5px 10px;font-family:monospace;
  max-width:260px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;
  cursor:pointer;transition:border-color 0.2s;
}
#server-url-display:hover{border-color:var(--acc)}
.status-pill{
  display:flex;align-items:center;gap:6px;
  font-size:11px;color:var(--text2);
  background:var(--s2);border:1px solid var(--border);
  border-radius:20px;padding:4px 10px;
}
.status-dot{width:7px;height:7px;border-radius:50%;background:var(--text3)}
.status-dot.ok{background:var(--green);box-shadow:0 0 8px var(--green)}
.status-dot.err{background:var(--red)}
.status-dot.spin{background:var(--gold);animation:blink 1s infinite}
@keyframes blink{0%,100%{opacity:1}50%{opacity:0.2}}

/* ── LAYOUT ── */
#layout{display:flex;flex:1;overflow:hidden;position:relative;z-index:1}

/* ── SIDEBAR ── */
#sidebar{
  width:230px;flex-shrink:0;
  background:var(--s1);border-right:1px solid var(--border);
  display:flex;flex-direction:column;overflow-y:auto;
  padding:16px 0 24px;
}
.sidebar-sec{margin-bottom:4px}
.sidebar-lbl{
  font-size:10px;letter-spacing:0.15em;text-transform:uppercase;
  color:var(--text3);padding:10px 16px 4px;
}
.nav-item{
  display:flex;align-items:center;gap:10px;
  padding:9px 14px;cursor:pointer;border-radius:0;
  color:var(--text2);font-size:13px;font-weight:500;
  transition:all 0.15s;margin:1px 8px;border-radius:7px;
  position:relative;
}
.nav-item:hover{background:rgba(79,110,247,0.08);color:var(--acc3)}
.nav-item.active{
  background:linear-gradient(135deg,rgba(79,110,247,0.15),rgba(79,110,247,0.05));
  color:var(--acc2);border:1px solid rgba(79,110,247,0.2);
}
.nav-icon{font-size:15px;width:20px;text-align:center}
.nav-count{margin-left:auto;font-size:10px;color:var(--text3);
  background:var(--s2);border:1px solid var(--border);
  padding:1px 6px;border-radius:8px;font-weight:700;}
.nav-item.active .nav-count{background:rgba(79,110,247,0.15);color:var(--acc2);border-color:rgba(79,110,247,0.25)}

/* sidebar footer */
.sidebar-footer{margin-top:auto;padding:12px 8px 0;border-top:1px solid var(--border)}

/* ── MAIN ── */
#main{flex:1;overflow-y:auto;display:flex;flex-direction:column}

/* ── CONNECT SCREEN ── */
#connect-screen{
  flex:1;display:flex;align-items:center;justify-content:center;padding:40px;
}
.connect-card{
  background:var(--s1);border:1px solid var(--border);
  border-radius:18px;padding:44px;max-width:520px;width:100%;
  box-shadow:var(--sh);
}
.connect-card .logo-big{
  width:56px;height:56px;border-radius:14px;margin-bottom:20px;
  background:linear-gradient(135deg,var(--acc),var(--cyan));
  display:flex;align-items:center;justify-content:center;
  font-family:'Clash Display',sans-serif;font-size:24px;font-weight:700;
  color:#fff;box-shadow:0 0 24px rgba(79,110,247,0.4);
}
.connect-card h2{
  font-family:'Clash Display',sans-serif;font-size:28px;font-weight:600;
  margin-bottom:8px;letter-spacing:-0.02em;
}
.connect-card p{color:var(--text2);font-size:13px;line-height:1.7;margin-bottom:28px}
.form-group{margin-bottom:16px}
.form-label{display:block;font-size:11px;letter-spacing:0.1em;text-transform:uppercase;color:var(--text2);margin-bottom:6px}
.form-input{
  width:100%;background:var(--bg);border:1px solid var(--border2);
  border-radius:8px;padding:11px 14px;color:var(--text);
  font-family:'Cabinet Grotesk',sans-serif;font-size:13px;outline:none;
  transition:border-color 0.2s,box-shadow 0.2s;
}
.form-input:focus{border-color:var(--acc);box-shadow:0 0 0 3px rgba(79,110,247,0.12)}
.form-input::placeholder{color:var(--text3)}
.btn-primary{
  width:100%;padding:13px;border:none;border-radius:9px;
  background:linear-gradient(135deg,var(--acc),#3550e0);
  color:#fff;font-family:'Cabinet Grotesk',sans-serif;
  font-size:14px;font-weight:700;cursor:pointer;letter-spacing:0.02em;
  transition:opacity 0.2s,transform 0.1s;
  box-shadow:0 4px 16px rgba(79,110,247,0.35);
}
.btn-primary:hover{opacity:0.9}
.btn-primary:active{transform:scale(0.98)}
.divider{display:flex;align-items:center;gap:12px;margin:20px 0;color:var(--text3);font-size:12px}
.divider::before,.divider::after{content:'';flex:1;height:1px;background:var(--border)}

/* ── DASHBOARD ── */
#dashboard-view{flex:1;overflow-y:auto;padding:28px}
.page-header{margin-bottom:24px}
.page-title{font-family:'Clash Display',sans-serif;font-size:26px;font-weight:600;letter-spacing:-0.02em;margin-bottom:4px}
.page-sub{color:var(--text2);font-size:13px}
.stats-row{display:grid;grid-template-columns:repeat(auto-fill,minmax(170px,1fr));gap:14px;margin-bottom:28px}
.stat-card{
  background:var(--s1);border:1px solid var(--border);border-radius:12px;
  padding:20px;transition:border-color 0.2s,transform 0.2s;cursor:default;
}
.stat-card:hover{border-color:var(--border2);transform:translateY(-2px)}
.stat-label{font-size:11px;letter-spacing:0.1em;text-transform:uppercase;color:var(--text2);margin-bottom:10px;display:flex;align-items:center;gap:6px}
.stat-value{font-family:'Clash Display',sans-serif;font-size:36px;font-weight:600;letter-spacing:-0.03em}
.stat-value.blue{color:var(--acc2)}
.stat-value.cyan{color:var(--cyan)}
.stat-value.green{color:var(--green)}
.stat-value.gold{color:var(--gold)}
.stat-sub{font-size:11px;color:var(--text3);margin-top:4px}

.section-title{font-family:'Clash Display',sans-serif;font-size:16px;font-weight:600;margin-bottom:14px;display:flex;align-items:center;gap:8px}
.apps-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:16px}
.app-card{
  background:var(--s1);border:1px solid var(--border);border-radius:12px;
  padding:20px;cursor:pointer;transition:all 0.2s;
}
.app-card:hover{border-color:var(--acc);background:var(--s2);transform:translateY(-2px)}
.app-card-head{display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:14px}
.app-icon{
  width:40px;height:40px;border-radius:10px;
  background:linear-gradient(135deg,var(--acc),var(--cyan));
  display:flex;align-items:center;justify-content:center;font-size:18px;
  flex-shrink:0;
}
.app-info{flex:1;margin-left:12px}
.app-name{font-family:'Clash Display',sans-serif;font-size:16px;font-weight:600;letter-spacing:-0.01em}
.app-slug{font-size:11px;color:var(--text3);font-family:monospace;margin-top:2px}
.app-key{
  font-size:11px;color:var(--text3);font-family:monospace;
  background:var(--bg);border:1px solid var(--border);
  border-radius:5px;padding:5px 8px;margin-bottom:12px;
  overflow:hidden;text-overflow:ellipsis;white-space:nowrap;
  cursor:pointer;transition:border-color 0.2s;
}
.app-key:hover{border-color:var(--acc)}
.app-meta{display:flex;gap:12px;flex-wrap:wrap}
.app-badge{
  font-size:11px;font-weight:600;padding:3px 8px;border-radius:6px;
  background:rgba(79,110,247,0.1);color:var(--acc2);border:1px solid rgba(79,110,247,0.15);
}
.app-badge.cyan{background:rgba(56,217,192,0.1);color:var(--cyan);border-color:rgba(56,217,192,0.15)}
.app-actions{display:flex;gap:8px;margin-top:14px;padding-top:14px;border-top:1px solid var(--border)}

/* ── BUTTONS ── */
.btn{
  border:none;border-radius:7px;padding:8px 14px;
  font-family:'Cabinet Grotesk',sans-serif;font-size:12px;font-weight:700;
  cursor:pointer;transition:all 0.15s;display:inline-flex;align-items:center;gap:6px;
  letter-spacing:0.02em;
}
.btn:hover{opacity:0.85}
.btn:active{transform:scale(0.97)}
.btn-blue{background:rgba(79,110,247,0.15);border:1px solid rgba(79,110,247,0.25);color:var(--acc2)}
.btn-blue:hover{background:rgba(79,110,247,0.25)}
.btn-cyan{background:rgba(56,217,192,0.1);border:1px solid rgba(56,217,192,0.2);color:var(--cyan)}
.btn-red{background:rgba(240,80,80,0.1);border:1px solid rgba(240,80,80,0.2);color:var(--red)}
.btn-green{background:rgba(64,212,128,0.1);border:1px solid rgba(64,212,128,0.2);color:var(--green)}
.btn-outline{background:transparent;border:1px solid var(--border2);color:var(--text2)}
.btn-outline:hover{border-color:var(--acc);color:var(--acc2)}
.btn-solid{background:linear-gradient(135deg,var(--acc),#3550e0);color:#fff;box-shadow:0 3px 12px rgba(79,110,247,0.3)}

/* ── APP DETAIL VIEW ── */
#app-view{flex:1;overflow-y:auto;padding:28px;display:flex;flex-direction:column;gap:20px}
.back-btn{
  display:inline-flex;align-items:center;gap:6px;
  font-size:12px;color:var(--text2);cursor:pointer;
  transition:color 0.15s;margin-bottom:4px;
  background:none;border:none;font-family:'Cabinet Grotesk',sans-serif;
}
.back-btn:hover{color:var(--acc2)}
.app-header-row{display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px}
.app-title-block{display:flex;align-items:center;gap:14px}
.app-icon-lg{
  width:52px;height:52px;border-radius:13px;
  background:linear-gradient(135deg,var(--acc),var(--cyan));
  display:flex;align-items:center;justify-content:center;font-size:24px;
  box-shadow:0 0 20px rgba(79,110,247,0.3);
}
.app-view-name{font-family:'Clash Display',sans-serif;font-size:24px;font-weight:600;letter-spacing:-0.02em}
.app-view-slug{font-size:12px;color:var(--text3);font-family:monospace;margin-top:2px}

/* API Key box */
.api-key-box{
  background:var(--s2);border:1px solid var(--border2);border-radius:10px;padding:16px 20px;
  display:flex;align-items:center;justify-content:space-between;gap:12px;
}
.api-key-label{font-size:11px;letter-spacing:0.1em;text-transform:uppercase;color:var(--text2);margin-bottom:4px}
.api-key-val{
  font-family:monospace;font-size:14px;color:var(--acc2);
  letter-spacing:0.05em;cursor:pointer;
}
.api-key-val.masked{color:var(--text3);letter-spacing:0.02em}

/* Collections table */
.collections-section{background:var(--s1);border:1px solid var(--border);border-radius:12px;overflow:hidden}
.section-header{
  display:flex;align-items:center;justify-content:space-between;
  padding:16px 20px;border-bottom:1px solid var(--border);
}
.section-head-title{font-family:'Clash Display',sans-serif;font-size:15px;font-weight:600}
table{width:100%;border-collapse:collapse}
thead th{
  background:var(--s2);color:var(--text3);
  font-size:10px;letter-spacing:0.12em;text-transform:uppercase;
  padding:11px 20px;text-align:left;border-bottom:1px solid var(--border);
  white-space:nowrap;
}
tbody tr{border-bottom:1px solid rgba(30,35,64,0.6);transition:background 0.1s}
tbody tr:last-child{border-bottom:none}
tbody tr:hover{background:rgba(79,110,247,0.03)}
tbody td{padding:12px 20px;font-size:13px;vertical-align:middle}
td .mono{font-family:monospace;font-size:12px;color:var(--acc3)}
td .count{font-size:11px;color:var(--text2)}
.empty-row td{text-align:center;padding:40px;color:var(--text3)}

/* ── DATA BROWSER ── */
#data-view{flex:1;overflow-y:auto;padding:28px;display:flex;flex-direction:column;gap:16px}
.toolbar{display:flex;align-items:center;gap:10px;flex-wrap:wrap}
.search-input{
  background:var(--s2);border:1px solid var(--border2);border-radius:7px;
  padding:8px 14px;color:var(--text);font-family:'Cabinet Grotesk',sans-serif;
  font-size:13px;outline:none;width:220px;transition:border-color 0.2s;
}
.search-input:focus{border-color:var(--acc)}
.search-input::placeholder{color:var(--text3)}
.table-wrap{
  background:var(--s1);border:1px solid var(--border);border-radius:12px;
  overflow:auto;flex:1;max-height:calc(100vh - 230px);
}
.data-table thead th{cursor:pointer;user-select:none}
.data-table thead th:hover{color:var(--acc2)}
.data-table thead th.sorted{color:var(--acc2)}
.data-table tbody td{max-width:220px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.cell-id{font-family:monospace;font-size:11px;color:var(--text3)}
.row-actions{display:flex;gap:6px}
.icon-btn{
  background:transparent;border:1px solid var(--border);border-radius:5px;
  padding:4px 8px;cursor:pointer;font-size:11px;color:var(--text2);
  transition:all 0.15s;
}
.icon-btn:hover.edit-btn{border-color:var(--acc);color:var(--acc2)}
.icon-btn:hover.del-btn{border-color:var(--red);color:var(--red)}
.pagination{display:flex;align-items:center;gap:8px;justify-content:flex-end}
.page-info{font-size:12px;color:var(--text3)}
.page-btn{
  background:transparent;border:1px solid var(--border2);border-radius:5px;
  padding:5px 10px;color:var(--text2);cursor:pointer;font-size:12px;
  transition:all 0.15s;
}
.page-btn:hover:not(:disabled){border-color:var(--acc);color:var(--acc2)}
.page-btn:disabled{opacity:0.3;cursor:not-allowed}
.page-btn.active{background:rgba(79,110,247,0.15);border-color:var(--acc);color:var(--acc2)}

/* ── MODAL ── */
.modal-overlay{
  position:fixed;inset:0;background:rgba(0,0,0,0.8);
  display:flex;align-items:center;justify-content:center;z-index:200;
  backdrop-filter:blur(6px);opacity:0;pointer-events:none;transition:opacity 0.2s;
}
.modal-overlay.open{opacity:1;pointer-events:all}
.modal{
  background:var(--s1);border:1px solid var(--border2);border-radius:16px;
  padding:32px;width:90%;max-width:500px;max-height:90vh;overflow-y:auto;
  box-shadow:0 24px 64px rgba(0,0,0,0.8);
  transform:translateY(16px);transition:transform 0.2s;
}
.modal-overlay.open .modal{transform:translateY(0)}
.modal-title{
  font-family:'Clash Display',sans-serif;font-size:20px;font-weight:600;
  margin-bottom:20px;display:flex;align-items:center;gap:10px;letter-spacing:-0.01em;
}
.modal-grid{display:grid;grid-template-columns:1fr 1fr;gap:14px}
.modal-grid .span2{grid-column:1/-1}
.modal-footer{display:flex;gap:10px;margin-top:24px;justify-content:flex-end}
.form-select{
  width:100%;background:var(--bg);border:1px solid var(--border2);
  border-radius:8px;padding:11px 14px;color:var(--text);
  font-family:'Cabinet Grotesk',sans-serif;font-size:13px;outline:none;
}
.form-select:focus{border-color:var(--acc)}
.form-textarea{
  width:100%;background:var(--bg);border:1px solid var(--border2);
  border-radius:8px;padding:11px 14px;color:var(--text);
  font-family:monospace;font-size:13px;outline:none;resize:vertical;min-height:120px;
  transition:border-color 0.2s;
}
.form-textarea:focus{border-color:var(--acc)}

/* ── TOAST ── */
#toast-area{position:fixed;bottom:24px;right:24px;z-index:300;display:flex;flex-direction:column;gap:8px}
.toast{
  background:var(--s1);border:1px solid var(--border2);border-radius:9px;
  padding:12px 18px;font-size:13px;color:var(--text);
  box-shadow:var(--sh);display:flex;align-items:center;gap:10px;max-width:320px;
  animation:toastIn 0.2s ease both;
}
.toast.success{border-color:rgba(64,212,128,0.35);background:rgba(12,14,26,0.98)}
.toast.error{border-color:rgba(240,80,80,0.35)}
.toast.info{border-color:rgba(79,110,247,0.35)}
@keyframes toastIn{from{transform:translateX(30px);opacity:0}to{transform:none;opacity:1}}

/* ── LOADER ── */
.loader{
  display:inline-block;width:14px;height:14px;border-radius:50%;
  border:2px solid var(--border2);border-top-color:var(--acc);
  animation:spin 0.7s linear infinite;
}
@keyframes spin{to{transform:rotate(360deg)}}

/* ── CODE BLOCK ── */
.code-block{
  background:var(--bg);border:1px solid var(--border);border-radius:8px;
  padding:14px;font-family:monospace;font-size:12px;color:var(--acc3);
  line-height:1.7;overflow-x:auto;margin:8px 0;
}
.code-block .kw{color:var(--pink)}
.code-block .str{color:var(--green)}
.code-block .cm{color:var(--text3)}

/* scrollbar */
::-webkit-scrollbar{width:5px;height:5px}
::-webkit-scrollbar-track{background:var(--bg)}
::-webkit-scrollbar-thumb{background:var(--border2);border-radius:3px}
::-webkit-scrollbar-thumb:hover{background:var(--acc)}

/* chip */
.chip{display:inline-block;padding:2px 8px;border-radius:6px;font-size:11px;font-weight:700}
.chip-col{background:rgba(79,110,247,0.12);color:var(--acc2)}
.chip-tbl{background:rgba(56,217,192,0.1);color:var(--cyan)}

/* row entry animation */
tbody tr{animation:rowIn 0.12s ease both}
@keyframes rowIn{from{opacity:0;transform:translateY(-3px)}to{opacity:1;transform:none}}

/* ── HIDDEN ── */
.hidden{display:none!important}
</style>
</head>
<body>

<!-- TOP BAR -->
<div id="topbar">
  <div class="brand" onclick="goHome()">
    <div class="brand-logo">NC</div>
    <div>
      <div class="brand-name">NitinCloud</div>
      <div class="brand-tag">Personal BaaS Platform</div>
    </div>
  </div>
  <div class="topbar-right">
    <div id="server-url-display" onclick="openConfig()" title="Click to change server URL">Not connected</div>
    <div class="status-pill">
      <div class="status-dot" id="status-dot"></div>
      <span id="status-text">Offline</span>
    </div>
  </div>
</div>

<!-- LAYOUT -->
<div id="layout">

  <!-- SIDEBAR -->
  <nav id="sidebar">
