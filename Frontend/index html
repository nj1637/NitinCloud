  </div>
</div>

<!-- CREATE COLLECTION MODAL -->
<div class="modal-overlay" id="create-col-modal">
  <div class="modal">
    <div class="modal-title">🗂 New Collection</div>
    <div class="form-group">
      <label class="form-label">Collection Name *</label>
      <input class="form-input" id="new-col-name" placeholder="e.g. products, customers, orders…"/>
    </div>
    <div class="form-group">
      <label class="form-label">Type</label>
      <select class="form-select" id="new-col-type">
