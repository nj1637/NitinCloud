          Connect to localhost:3000
        </button>
      </div>
    </div>

    <!-- DASHBOARD VIEW -->
    <div id="dashboard-view" class="hidden">
      <div class="page-header">
        <div class="page-title">🚀 Dashboard</div>
        <div class="page-sub">Your NitinCloud platform overview</div>
      </div>
      <div class="stats-row" id="stats-row">
        <div class="stat-card"><div class="stat-label">📱 Total Apps</div><div class="stat-value blue" id="stat-apps">—</div><div class="stat-sub">active projects</div></div>
        <div class="stat-card"><div class="stat-label">🗂 Collections</div><div class="stat-value cyan" id="stat-cols">—</div><div class="stat-sub">across all apps</div></div>
        <div class="stat-card"><div class="stat-label">📄 Documents</div><div class="stat-value green" id="stat-docs">—</div><div class="stat-sub">total records stored</div></div>
        <div class="stat-card"><div class="stat-label">💾 DB Size</div><div class="stat-value gold" id="stat-size">—</div><div class="stat-sub">SQLite on Render</div></div>
      </div>
      <div class="section-title">📱 Your Apps <button class="btn btn-solid" style="margin-left:auto;font-size:12px" onclick="openCreateApp()">+ New App</button></div>
      <div class="apps-grid" id="apps-grid"></div>
    </div>

    <!-- APP DETAIL VIEW -->
    <div id="app-view" class="hidden">
      <button class="back-btn" onclick="goHome()">← Back to Dashboard</button>
      <div class="app-header-row">
        <div class="app-title-block">
          <div class="app-icon-lg" id="av-icon">📱</div>
          <div>
            <div class="app-view-name" id="av-name"></div>
            <div class="app-view-slug" id="av-slug"></div>
          </div>
        </div>
        <div style="display:flex;gap:8px">
          <button class="btn btn-outline" onclick="rotateKey()">🔄 Rotate Key</button>
          <button class="btn btn-red" onclick="deleteCurrentApp()">🗑 Delete App</button>
