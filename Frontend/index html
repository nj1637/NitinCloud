      </div>

      <!-- API Key Box -->
      <div class="api-key-box">
        <div style="flex:1;min-width:0">
          <div class="api-key-label">API Key — use this in your tools</div>
          <div class="api-key-val masked" id="av-apikey" onclick="toggleKeyVisibility()" title="Click to show/hide">••••••••••••••••••••••••••••</div>
        </div>
        <div style="display:flex;gap:8px;flex-shrink:0">
          <button class="btn btn-outline" onclick="copyApiKey()">📋 Copy</button>
          <button class="btn btn-blue" onclick="showCodeSnippet()">{'</>'}  Use in Tool</button>
        </div>
