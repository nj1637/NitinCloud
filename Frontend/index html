      <label class="form-label">Master Key</label>
      <input class="form-input" type="password" id="cfg-key" placeholder="Your master key"/>
    </div>
    <div class="modal-footer">
      <button class="btn btn-outline" onclick="closeModal('config-modal')">Cancel</button>
      <button class="btn btn-solid" onclick="saveConfig()">Save & Reconnect</button>
    </div>
  </div>
</div>

<!-- CODE SNIPPET MODAL -->
<div class="modal-overlay" id="snippet-modal">
  <div class="modal" style="max-width:620px">
    <div class="modal-title">{'</>'} Use in Your Tool</div>
    <div style="font-size:13px;color:var(--text2);margin-bottom:12px">Copy this SDK snippet into any HTML tool to start reading/writing data instantly.</div>
    <div class="code-block" id="snippet-content"></div>
    <div class="modal-footer">
      <button class="btn btn-outline" onclick="closeModal('snippet-modal')">Close</button>
      <button class="btn btn-solid" onclick="copySnippet()">📋 Copy Code</button>
    </div>
  </div>
</div>

<div id="toast-area"></div>

<script>
// ═══════════════════════════════════════════════════════
//  STATE
// ═══════════════════════════════════════════════════════
let CFG = { url: '', masterKey: '' };
let APPS = [];
let currentApp = null;
let currentCollection = null;
let allDocs = [];
let editingDocId = null;
let sortCol = null, sortDir = -1;
let currentPage = 1;
const PAGE_SIZE = 25;

const APP_ICONS = ['📱','🛒','🏥','🎵','📦','👥','🧾','🚀','💊','🌿','🔧','📊','🎯','💡','🏪'];

// ═══════════════════════════════════════════════════════
//  INIT
// ═══════════════════════════════════════════════════════
window.onload = () => {
  const saved = localStorage.getItem('nc_config');
  if (saved) {
    CFG = JSON.parse(saved);
    init();
  }
};

async function init() {
  setStatus('spin', 'Connecting…');
  document.getElementById('server-url-display').textContent = CFG.url;
  try {
    await loadStats();
    await loadApps();
    hideConnect();
    showView('dashboard-view');
    setStatus('ok', 'Connected');
    toast('Connected to NitinCloud API', 'success');
  } catch(e) {
    setStatus('err', 'Connection failed');
    toast('Cannot reach server. Check URL and master key.', 'error');
  }
}

// ═══════════════════════════════════════════════════════
//  CONNECTION
// ═══════════════════════════════════════════════════════
async function connect() {
  const url = document.getElementById('server-url-input').value.trim().replace(/\/$/,'');
  const key = document.getElementById('master-key-input').value.trim();
  if (!url || !key) { toast('URL and master key required', 'error'); return; }
  CFG = { url, masterKey: key };
  localStorage.setItem('nc_config', JSON.stringify(CFG));
  await init();
}

async function connectLocal() {
  document.getElementById('server-url-input').value = 'http://localhost:3000';
  document.getElementById('master-key-input').value = 'nitincloud-master-2024';
  await connect();
}

function openConfig() {
  document.getElementById('cfg-url').value = CFG.url;
  document.getElementById('cfg-key').value = CFG.masterKey;
  openModal('config-modal');
}

async function saveConfig() {
  const url = document.getElementById('cfg-url').value.trim().replace(/\/$/,'');
  const key = document.getElementById('cfg-key').value.trim();
  CFG = { url, masterKey: key };
  localStorage.setItem('nc_config', JSON.stringify(CFG));
  closeModal('config-modal');
  await init();
}

// ═══════════════════════════════════════════════════════
//  API CALLS
// ═══════════════════════════════════════════════════════
async function api(path, opts = {}) {
  const headers = { 'Content-Type': 'application/json', 'x-master-key': CFG.masterKey };
  const r = await fetch(CFG.url + path, { headers, ...opts });
  if (!r.ok) {
    const e = await r.json().catch(() => ({ error: r.statusText }));
    throw new Error(e.error || r.statusText);
  }
  return r.json();
}

async function appApi(path, opts = {}) {
  if (!currentApp) throw new Error('No app selected');
  const headers = { 'Content-Type': 'application/json', 'x-api-key': currentApp.api_key };
  const r = await fetch(CFG.url + path, { headers, ...opts });
  if (!r.ok) {
    const e = await r.json().catch(() => ({ error: r.statusText }));
    throw new Error(e.error || r.statusText);
  }
  return r.json();
}

// ═══════════════════════════════════════════════════════
//  LOAD DATA
// ═══════════════════════════════════════════════════════
async function loadStats() {
  const { stats } = await api('/admin/stats');
  document.getElementById('stat-apps').textContent  = stats.total_apps;
  document.getElementById('stat-cols').textContent  = stats.total_collections;
  document.getElementById('stat-docs').textContent  = stats.total_documents.toLocaleString();
  document.getElementById('stat-size').textContent  = stats.db_size_kb + ' KB';
}

async function loadApps() {
  const { apps } = await api('/admin/apps');
  APPS = apps;
  document.getElementById('apps-count').textContent = apps.length;
  renderAppsGrid();
}

// ═══════════════════════════════════════════════════════
//  NAVIGATION
// ═══════════════════════════════════════════════════════
function setActive(id) {
  document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));
  const el = document.getElementById(id);
  if (el) el.classList.add('active');
}

function showView(id) {
  ['dashboard-view','app-view','data-view','docs-view'].forEach(v => {
    document.getElementById(v).classList.add('hidden');
  });
  document.getElementById(id).classList.remove('hidden');
}

function hideConnect() {
  document.getElementById('connect-screen').classList.add('hidden');
}

function goHome() {
  setActive('nav-home');
  currentApp = null;
  currentCollection = null;
  document.getElementById('app-nav-items').innerHTML = '<div style="color:var(--text3);font-size:12px;padding:4px 0">No app selected</div>';
  showView('dashboard-view');
  loadStats();
  loadApps();
}

function showApps() {
  setActive('nav-apps');
  showView('dashboard-view');
}

// ═══════════════════════════════════════════════════════
//  APPS
// ═══════════════════════════════════════════════════════
function renderAppsGrid() {
  const grid = document.getElementById('apps-grid');
  if (APPS.length === 0) {
    grid.innerHTML = `<div style="grid-column:1/-1;text-align:center;padding:60px;color:var(--text3)">
      <div style="font-size:48px;margin-bottom:16px;opacity:0.3">📱</div>
      <div style="font-size:16px;color:var(--text2);margin-bottom:8px">No apps yet</div>
      <div>Click "+ New App" to create your first app</div>
    </div>`;
    return;
  }
  grid.innerHTML = APPS.map((app, i) => {
    const icon = APP_ICONS[i % APP_ICONS.length];
    return `
    <div class="app-card" onclick="openApp('${app.id}')">
      <div class="app-card-head">
        <div class="app-icon">${icon}</div>
        <div class="app-info">
          <div class="app-name">${app.name}</div>
          <div class="app-slug">${app.slug}</div>
        </div>
      </div>
      <div class="app-key" onclick="event.stopPropagation();copyText('${app.api_key}','API Key')" title="Click to copy API key">
        🔑 ${app.api_key.slice(0,28)}…
      </div>
      <div class="app-meta">
        <span class="app-badge">${(app.collections||[]).length} collections</span>
        <span class="app-badge cyan">${app.doc_count || 0} docs</span>
        ${app.description ? `<span style="font-size:11px;color:var(--text3)">${app.description}</span>` : ''}
      </div>
      <div class="app-actions" onclick="event.stopPropagation()">
        <button class="btn btn-blue" onclick="openApp('${app.id}')">Open →</button>
        <button class="btn btn-outline" onclick="copyText('${app.api_key}','API Key')">📋 Copy Key</button>
      </div>
    </div>`;
  }).join('');
}

function openCreateApp() { openModal('create-app-modal'); }

async function createApp() {
  const name = document.getElementById('new-app-name').value.trim();
  const desc = document.getElementById('new-app-desc').value.trim();
  if (!name) { toast('App name required', 'error'); return; }
  try {
    const { app } = await api('/admin/apps', {
      method: 'POST',
      body: JSON.stringify({ name, description: desc })
    });
    closeModal('create-app-modal');
    document.getElementById('new-app-name').value = '';
    document.getElementById('new-app-desc').value = '';
    toast(`App "${app.name}" created!`, 'success');
    await loadApps();
    openApp(app.id);
  } catch(e) { toast('Error: ' + e.message, 'error'); }
}

async function openApp(id) {
  const app = APPS.find(a => a.id === id) || (await api(`/admin/apps/${id}`)).app;
  currentApp = app;
  showView('app-view');
  setActive('nav-apps');
  renderAppView();
}

function renderAppView() {
  const app = currentApp;
  const i = APPS.findIndex(a => a.id === app.id);
  const icon = APP_ICONS[i >= 0 ? i % APP_ICONS.length : 0];
  document.getElementById('av-icon').textContent = icon;
  document.getElementById('av-name').textContent = app.name;
  document.getElementById('av-slug').textContent = app.slug;
  document.getElementById('av-apikey').dataset.key = app.api_key;
  document.getElementById('av-apikey').textContent = '••••••••••••••••••••••••••••';
  document.getElementById('av-apikey').classList.add('masked');

  // Sidebar nav for this app
  const cols = app.collections || [];
  const navHtml = cols.length === 0
    ? '<div style="color:var(--text3);font-size:12px;padding:4px 0">No collections yet</div>'
    : cols.map(c => `
        <div class="nav-item" onclick="openCollection('${c.name}')">
          <span class="nav-icon">${c.type==='table'?'📋':'📄'}</span>
          <span style="overflow:hidden;text-overflow:ellipsis;white-space:nowrap">${c.name}</span>
        </div>`).join('');
  document.getElementById('app-nav-items').innerHTML = navHtml;

  renderCollectionsTable(cols);
}

function renderCollectionsTable(cols) {
  const tbody = document.getElementById('collections-table');
  if (!cols || cols.length === 0) {
    tbody.innerHTML = `<tr class="empty-row"><td colspan="5">No collections yet. Create one above.</td></tr>`;
    return;
  }
  tbody.innerHTML = cols.map(c => `
    <tr>
      <td><span class="mono">${c.name}</span></td>
      <td><span class="chip ${c.type==='table'?'chip-tbl':'chip-col'}">${c.type}</span></td>
      <td><span class="count">${c.doc_count || 0} documents</span></td>
      <td><span class="count">${new Date(c.created_at).toLocaleDateString('en-IN')}</span></td>
      <td>
        <div class="row-actions">
          <button class="icon-btn edit-btn" onclick="openCollection('${c.name}')">Browse →</button>
          <button class="icon-btn del-btn" onclick="deleteCollection('${c.name}')">🗑</button>
        </div>
      </td>
    </tr>
  `).join('');
}

function toggleKeyVisibility() {
  const el = document.getElementById('av-apikey');
  if (el.classList.contains('masked')) {
    el.textContent = el.dataset.key;
    el.classList.remove('masked');
  } else {
    el.textContent = '••••••••••••••••••••••••••••';
    el.classList.add('masked');
  }
}

function copyApiKey() {
  const key = document.getElementById('av-apikey').dataset.key;
  copyText(key, 'API Key');
}

async function rotateKey() {
  if (!confirm('Rotate API key? All tools using the old key will stop working.')) return;
  try {
    const { api_key } = await api(`/admin/apps/${currentApp.id}/rotate-key`, { method: 'POST' });
    currentApp.api_key = api_key;
    document.getElementById('av-apikey').dataset.key = api_key;
    document.getElementById('av-apikey').textContent = api_key;
    document.getElementById('av-apikey').classList.remove('masked');
    toast('API key rotated! Update your tools.', 'success');
    await loadApps();
  } catch(e) { toast('Error: ' + e.message, 'error'); }
}

async function deleteCurrentApp() {
  if (!confirm(`Delete "${currentApp.name}"? All data will be permanently lost.`)) return;
  try {
    await api(`/admin/apps/${currentApp.id}`, { method: 'DELETE' });
    toast('App deleted', 'success');
    goHome();
  } catch(e) { toast('Error: ' + e.message, 'error'); }
}

// ═══════════════════════════════════════════════════════
//  COLLECTIONS
// ═══════════════════════════════════════════════════════
function openCreateCollection() { openModal('create-col-modal'); }

async function createCollection() {
  const name = document.getElementById('new-col-name').value.trim().toLowerCase().replace(/\s+/g,'-');
  const type = document.getElementById('new-col-type').value;
  if (!name) { toast('Name required', 'error'); return; }
  try {
    await appApi('/api/collections', { method: 'POST', body: JSON.stringify({ name, type }) });
    closeModal('create-col-modal');
    document.getElementById('new-col-name').value = '';
    toast(`Collection "${name}" created!`, 'success');
    // Refresh app
    const { app } = await api(`/admin/apps/${currentApp.id}`);
    currentApp = app;
    APPS = APPS.map(a => a.id === app.id ? app : a);
    renderAppView();
  } catch(e) { toast('Error: ' + e.message, 'error'); }
}

async function deleteCollection(name) {
  if (!confirm(`Delete collection "${name}"? All documents will be deleted.`)) return;
  try {
    await appApi(`/api/collections/${name}`, { method: 'DELETE' });
    toast(`Collection "${name}" deleted`, 'success');
    const { app } = await api(`/admin/apps/${currentApp.id}`);
    currentApp = app;
    APPS = APPS.map(a => a.id === app.id ? app : a);
    renderAppView();
  } catch(e) { toast('Error: ' + e.message, 'error'); }
}

// ═══════════════════════════════════════════════════════
//  DATA BROWSER
// ═══════════════════════════════════════════════════════
async function openCollection(name) {
  currentCollection = name;
  currentPage = 1;
  sortCol = null;
  showView('data-view');
  document.getElementById('dv-title').textContent = `📄 ${name}`;
  document.getElementById('dv-search').value = '';
  await refreshDocs();
}

function backToApp() {
  currentCollection = null;
  showView('app-view');
}

async function refreshDocs() {
  document.getElementById('dv-sub').textContent = 'Loading…';
  try {
    const { data, total } = await appApi(`/api/${currentCollection}?limit=500`);
    allDocs = data;
    document.getElementById('dv-sub').textContent = `${total} documents in ${currentApp.name}`;
    renderDocsTable();
  } catch(e) { toast('Error loading: ' + e.message, 'error'); }
}

function filterDocs() { currentPage = 1; renderDocsTable(); }

function getFilteredDocs() {
  const q = document.getElementById('dv-search').value.toLowerCase();
  let rows = allDocs;
  if (q) rows = rows.filter(r => JSON.stringify(r).toLowerCase().includes(q));
  if (sortCol) {
    rows = [...rows].sort((a, b) => {
      const va = a[sortCol] ?? ''; const vb = b[sortCol] ?? '';
      const na = parseFloat(va), nb = parseFloat(vb);
      if (!isNaN(na) && !isNaN(nb)) return (na - nb) * sortDir;
      return String(va).localeCompare(String(vb)) * sortDir;
    });
  }
  return rows;
}

function renderDocsTable() {
  const rows = getFilteredDocs();
  if (rows.length === 0) {
    document.getElementById('dv-head').innerHTML = '';
    document.getElementById('dv-body').innerHTML = `<tr><td colspan="10" style="text-align:center;padding:50px;color:var(--text3)">No documents found. Click "+ Add Document" to create one.</td></tr>`;
    document.getElementById('dv-pagination').innerHTML = '';
    return;
  }

  // Collect all keys (excluding _id, _created_at, _updated_at for columns)
  const metaKeys = ['_id','_created_at','_updated_at'];
  const allKeys = [...new Set(rows.flatMap(r => Object.keys(r)))];
  const dataKeys = allKeys.filter(k => !metaKeys.includes(k)).slice(0, 7);
  const cols = [...dataKeys];

  // HEAD
  document.getElementById('dv-head').innerHTML = '<tr>' + cols.map(k => {
    const arr = sortCol === k ? (sortDir === 1 ? ' ↑' : ' ↓') : '';
    return `<th class="${sortCol===k?'sorted':''}" onclick="sortDocs('${k}')">${k}${arr}</th>`;
  }).join('') + '<th>Actions</th></tr>';

  const total = rows.length;
  const totalPages = Math.max(1, Math.ceil(total / PAGE_SIZE));
  if (currentPage > totalPages) currentPage = totalPages;
  const paged = rows.slice((currentPage - 1) * PAGE_SIZE, currentPage * PAGE_SIZE);

  document.getElementById('dv-body').innerHTML = paged.map(row => {
    const cells = cols.map(k => {
      let v = row[k] ?? '';
      if (typeof v === 'object') v = JSON.stringify(v);
      return `<td title="${String(v).replace(/"/g,'&quot;')}">${v}</td>`;
    }).join('');
    return `<tr>${cells}<td><div class="row-actions">
      <button class="icon-btn edit-btn" onclick="openEditDoc('${row._id}')">✏</button>
      <button class="icon-btn del-btn" onclick="deleteDoc('${row._id}')">🗑</button>
    </div></td></tr>`;
  }).join('');

  // Pagination
  let pgHtml = `<span class="page-info">${total} docs</span>`;
  if (totalPages > 1) {
    pgHtml += `<button class="page-btn" onclick="goPg(${currentPage-1})" ${currentPage===1?'disabled':''}>‹</button>`;
    for (let p = Math.max(1,currentPage-2); p <= Math.min(totalPages,currentPage+2); p++)
      pgHtml += `<button class="page-btn ${p===currentPage?'active':''}" onclick="goPg(${p})">${p}</button>`;
    pgHtml += `<button class="page-btn" onclick="goPg(${currentPage+1})" ${currentPage===totalPages?'disabled':''}>›</button>`;
  }
  document.getElementById('dv-pagination').innerHTML = pgHtml;
}

function sortDocs(key) {
  if (sortCol === key) sortDir *= -1; else { sortCol = key; sortDir = 1; }
  renderDocsTable();
}
function goPg(p) { currentPage = p; renderDocsTable(); }

// ── CRUD ────────────────────────────────────────────────
function openAddDoc() {
  editingDocId = null;
  document.getElementById('doc-modal-title').textContent = '➕ Add Document';
  document.getElementById('doc-save-btn').textContent = 'Save Document';
  document.getElementById('doc-json').value = '{\n  \n}';
  openModal('doc-modal');
  setTimeout(() => document.getElementById('doc-json').focus(), 100);
}

function openEditDoc(id) {
  const doc = allDocs.find(d => d._id === id);
  if (!doc) return;
  editingDocId = id;
  document.getElementById('doc-modal-title').textContent = '✏ Edit Document';
  document.getElementById('doc-save-btn').textContent = 'Save Changes';
  const clean = { ...doc };
  delete clean._id; delete clean._created_at; delete clean._updated_at;
  document.getElementById('doc-json').value = JSON.stringify(clean, null, 2);
  openModal('doc-modal');
}

async function saveDoc() {
  const raw = document.getElementById('doc-json').value;
  let data;
  try { data = JSON.parse(raw); } catch(e) { toast('Invalid JSON: ' + e.message, 'error'); return; }
  const btn = document.getElementById('doc-save-btn');
  btn.disabled = true; btn.innerHTML = '<span class="loader"></span>';
  try {
    if (editingDocId) {
      await appApi(`/api/${currentCollection}/${editingDocId}`, { method: 'PATCH', body: JSON.stringify(data) });
      toast('Document updated', 'success');
    } else {
      await appApi(`/api/${currentCollection}`, { method: 'POST', body: JSON.stringify(data) });
      toast('Document added', 'success');
    }
    closeModal('doc-modal');
    await refreshDocs();
  } catch(e) { toast('Error: ' + e.message, 'error'); }
  btn.disabled = false; btn.textContent = editingDocId ? 'Save Changes' : 'Save Document';
}

async function deleteDoc(id) {
  if (!confirm('Delete this document?')) return;
  try {
    await appApi(`/api/${currentCollection}/${id}`, { method: 'DELETE' });
    allDocs = allDocs.filter(d => d._id !== id);
    renderDocsTable();
    toast('Deleted', 'success');
    loadStats();
  } catch(e) { toast('Error: ' + e.message, 'error'); }
}

function exportCollection() {
  const rows = getFilteredDocs();
  const json = JSON.stringify(rows, null, 2);
  const blob = new Blob([json], { type: 'application/json' });
  const a = document.createElement('a');
  a.href = URL.createObjectURL(blob);
  a.download = `${currentApp.slug}_${currentCollection}_${new Date().toISOString().slice(0,10)}.json`;
  a.click();
  toast('Exported as JSON', 'success');
}

