      <!-- Collections -->
      <div class="collections-section">
        <div class="section-header">
          <div class="section-head-title">🗂 Collections</div>
          <button class="btn btn-blue" onclick="openCreateCollection()">+ New Collection</button>
        </div>
        <table>
          <thead><tr>
            <th>Name</th><th>Type</th><th>Documents</th><th>Created</th><th>Actions</th>
          </tr></thead>
          <tbody id="collections-table"></tbody>
        </table>
      </div>
    </div>

    <!-- DATA BROWSER VIEW -->
    <div id="data-view" class="hidden">
      <div>
        <button class="back-btn" onclick="backToApp()">← Back to App</button>
        <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px;margin-top:8px">
          <div>
            <div class="page-title" id="dv-title"></div>
            <div class="page-sub" id="dv-sub"></div>
          </div>
          <div class="toolbar">
            <input class="search-input" id="dv-search" placeholder="🔍 Search…" oninput="filterDocs()"/>
            <button class="btn btn-outline" onclick="exportCollection()">📤 Export</button>
            <button class="btn btn-cyan" onclick="refreshDocs()">🔄 Refresh</button>
            <button class="btn btn-solid" onclick="openAddDoc()">+ Add Document</button>
          </div>
        </div>
      </div>
      <div class="table-wrap">
        <table class="data-table">
          <thead id="dv-head"></thead>
          <tbody id="dv-body"></tbody>
        </table>
      </div>
