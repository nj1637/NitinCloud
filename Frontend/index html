        <option value="table">Table (structured — SQL-style)</option>
      </select>
    </div>
    <div class="modal-footer">
      <button class="btn btn-outline" onclick="closeModal('create-col-modal')">Cancel</button>
      <button class="btn btn-solid" onclick="createCollection()">Create →</button>
    </div>
  </div>
</div>

<!-- ADD/EDIT DOCUMENT MODAL -->
<div class="modal-overlay" id="doc-modal">
  <div class="modal" style="max-width:580px">
    <div class="modal-title" id="doc-modal-title">Add Document</div>
    <div class="form-group">
      <label class="form-label">Document Data (JSON)</label>
      <textarea class="form-textarea" id="doc-json" style="min-height:180px" placeholder='{ "name": "Ashwagandha", "price": 299, "stock": 50 }'></textarea>
      <div style="font-size:11px;color:var(--text3);margin-top:6px">Enter valid JSON. All fields are flexible — no schema required.</div>
    </div>
    <div class="modal-footer">
      <button class="btn btn-outline" onclick="closeModal('doc-modal')">Cancel</button>
      <button class="btn btn-solid" id="doc-save-btn" onclick="saveDoc()">Save Document</button>
    </div>
  </div>
</div>

<!-- CONFIG MODAL -->
<div class="modal-overlay" id="config-modal">
  <div class="modal">
    <div class="modal-title">⚙ Server Settings</div>
    <div class="form-group">
      <label class="form-label">Server URL</label>
      <input class="form-input" id="cfg-url" placeholder="https://your-app.onrender.com"/>
    </div>
