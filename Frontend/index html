  <!-- MAIN -->
  <main id="main">

    <!-- CONNECT SCREEN -->
    <div id="connect-screen">
      <div class="connect-card">
        <div class="logo-big">NC</div>
        <h2>Welcome to NitinCloud</h2>
        <p>Your personal Backend-as-a-Service platform. Connect to your Render-hosted API server to start managing apps, collections, and data.</p>
        <div class="form-group">
          <label class="form-label">Render Server URL</label>
          <input class="form-input" id="server-url-input" placeholder="https://nitincloud-api.onrender.com"/>
